  booktitle = {Proceedings of the 4th International Conference on Historical Cryptology (HistoCrypt 2021)},
  editor    = {Carola Dahlke},
  year      = {2021},
  series    = {Linköping Electronic Conference Proceedings 183},
  pages     = {90--93},
  bibtex_show={true},
